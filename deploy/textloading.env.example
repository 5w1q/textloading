# 生产推荐（与 Ab 一致单独维护密钥文件）：
#   sudo mkdir -p /etc/textloading
#   sudo cp deploy/textloading.env.example /etc/textloading/textloading.env
#   sudo chmod 600 /etc/textloading/textloading.env
#   sudo nano /etc/textloading/textloading.env   # 填写 JWT_SECRET 等
#   cd /opt/textloading && ln -sf /etc/textloading/textloading.env deploy/textloading.env
#
# 本地开发：cp deploy/textloading.env.example deploy/textloading.env 后按需修改
#
# 格式：KEY=value（勿 export）；# 为注释
#
# --- 《Ab/docs/unified-infra-optimization-plan.md》textloading 应按这样接（§2.1 / §2.2 / §3 / §4.3）---
# PostgreSQL：库名固定为 textloading_app（与 ab_core、nano_genimg 等「同实例、分库」；用户在云上单独 CREATE DATABASE + 授权）
# Redis：DB index = 2，key 前缀 = tl:（文档 §2.2：Ab=0+ab:，Nano=1+nano:，textloading=2+tl:）
# 并发第一阶段基线（§3 + §4.3）：API workers=2、ARQ WORKER_MAX_JOBS=2、每服务连接池 pool_size=5 & max_overflow=5
# OSS（§2.3）：仅导出/归档需要时再配；未接 OSS 可不写任何 OSS 变量
# Nginx / 安全组（§1 + §5.3）：网关 HTTPS 反代 API；5432/6379 不对公网；容器访问宿主 PG/Redis 时用 host.docker.internal + extra_hosts
#
# 统一 PG/Redis 在宿主机、Docker 只跑 textloading 时示例（密码与用户换成运维实际值）：
#   DATABASE_URL=postgresql+asyncpg://tl_app:<PASSWORD>@host.docker.internal:5432/textloading_app
#   REDIS_URL=redis://host.docker.internal:6379/2
#   REDIS_PREFIX=tl:
# （compose 里需给 api、worker、bridge 增加 extra_hosts: host.docker.internal:host-gateway）
#
# 宿主机 PostgreSQL 必须允许「从 Docker 网桥进来」的 TCP，否则容器内会长时间超时（asyncpg TimeoutError）：
#   • postgresql.conf：listen_addresses = '*'（或至少包含 docker0 的地址，勿仅 127.0.0.1）
#   • pg_hba.conf：增加一行允许网桥（子网按实际调整，可先 ip -4 addr show docker0）
#       host  all  all  172.17.0.0/16  scram-sha-256
#   • 防火墙需放行「docker0 → 宿主 :5432」入站（本机回环无关）
# Redis 若也在宿主：地址不能只监听 127.0.0.1（需让 Docker 网关 IP 可达，或使用 Redis 7 的多 bind：`bind 127.0.0.1 <docker0-ip>`）；并限制防火墙勿对公网开放 6379。更简单：`REDIS_URL=redis://redis:6379/2` 走 compose 内 Redis。
# --- 与 Ab 单环境变量命名习惯的对应关系 ---
# Ab 示例：
#   DATABASE_URL=postgresql://ab_app:...@127.0.0.1:5432/ab_core
#   REDIS_URL=redis://127.0.0.1:6379/0
#   REDIS_PREFIX=ab:risk:
# 本项目：
#   • DATABASE_URL 必须用异步驱动：postgresql+asyncpg://（不要把 Ab 的 postgresql:// 原样粘贴）
#   • Redis 建议单独 logical DB（如 /2）+ 前缀，避免与 Ab 的 key 冲突；前缀可用 REDIS_KEY_PREFIX 或 REDIS_PREFIX
#   • 应用跑在 Docker 里时，不要用 127.0.0.1 指宿主机库——应写 compose 服务名（postgres/redis）
#     或宿主机映射地址 host.docker.internal（需在 compose 为该服务增加 extra_hosts: host.docker.internal:host-gateway）
#   • DB_SSL_REJECT_UNAUTHORIZED：当前未接异步库 SSL；连本机/内网无 TLS 的 PG 不必设置

JWT_SECRET=change-me-use-openssl-rand-hex-32
# --- 与 Ab 统一登录（hub 与 Ab 同二级域 sayhi-ab.asia）---
# JWT_SECRET 必须与 Ab 生产环境一致（例：/etc/ab/ab-server.env 内的 JWT_SECRET）。
# 浏览器会携带 Ab 下发的 httpOnly Cookie「ab_token」（Ab 常量 COOKIE_NAME）；若 Ab 改过 Cookie 名：
# AB_AUTH_COOKIE_NAME=ab_token
# Ab 需在 COOKIE_DOMAIN 使用 .sayhi-ab.asia，以便 hub.sayhi-ab.asia 请求带上会话。
# Hub 顶栏展示依赖 JWT payload（与签发 Ab Token 时写入的字段一致），可选字段示例：
#   nickname / display_name / custom_username / name → 自定义称呼；无则用 JWT 内 email，再无则用本站账号标识
#   is_vip 或 vip（bool/0/1）或 vip_level（>0）→ VIP 状态
#   points / credits / balance / score / remaining_points → 积分剩余；未传则 Hub 显示「—」
# 亦可把上述字段放在嵌套对象 user:{ ... } 内（与顶层互斥时顶层优先）。
AB_AUTH_COOKIE_NAME=ab_token

DATABASE_URL=postgresql+asyncpg://douyin:douyin@postgres:5432/textloading_app
REDIS_URL=redis://redis:6379/2
REDIS_KEY_PREFIX=tl:
# 与 Ab 命名一致时也可写：REDIS_PREFIX=tl:

DOUYIN_ADAPTER=http
DOUYIN_HTTP_RESOLVE_URL=http://bridge:9000/douyin/resolve?unique_id={unique_id}
DOUYIN_HTTP_FEED_URL=http://bridge:9000/douyin/feed?sec_uid={sec_uid}&cursor={cursor}

CORS_ORIGINS=https://hub.sayhi-ab.asia,http://localhost:5174,http://127.0.0.1:5174

# 生产建议保持 1：API lifespan 内会执行 init_db()/DDL，多 worker 并行 startup 易长时间卡住或撞锁（见 docker-compose 默认）
UVICORN_WORKERS=1
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
RATE_LIMIT_SYNC_PER_USER_PER_MINUTE=30
DOUYIN_FETCH_MAX_CONCURRENT=4

DOUYIN_HTTP_MAX_ATTEMPTS=5
DOUYIN_HTTP_RETRY_BACKOFF_BASE=0.5
WORKER_MAX_JOBS=2
WORKER_JOB_TIMEOUT=900

UPSTREAM_BASE_URL=http://host.docker.internal:19003
