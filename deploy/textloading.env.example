# 生产推荐（与 Ab 一致单独维护密钥文件）：
#   sudo mkdir -p /etc/textloading
#   sudo cp deploy/textloading.env.example /etc/textloading/textloading.env
#   sudo chmod 600 /etc/textloading/textloading.env
#   sudo nano /etc/textloading/textloading.env   # 填写 JWT_SECRET 等
#   cd /opt/textloading && ln -sf /etc/textloading/textloading.env deploy/textloading.env
#
# 本地开发：cp deploy/textloading.env.example deploy/textloading.env 后按需修改
#
# 格式：KEY=value（勿 export）；# 为注释

JWT_SECRET=change-me-use-openssl-rand-hex-32

DATABASE_URL=postgresql+asyncpg://douyin:douyin@postgres:5432/textloading_app
REDIS_URL=redis://redis:6379/2
REDIS_KEY_PREFIX=tl:

DOUYIN_ADAPTER=http
DOUYIN_HTTP_RESOLVE_URL=http://bridge:9000/douyin/resolve?unique_id={unique_id}
DOUYIN_HTTP_FEED_URL=http://bridge:9000/douyin/feed?sec_uid={sec_uid}&cursor={cursor}

CORS_ORIGINS=https://hub.sayhi-ab.asia,http://localhost:5174,http://127.0.0.1:5174

UVICORN_WORKERS=2
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
RATE_LIMIT_SYNC_PER_USER_PER_MINUTE=30
DOUYIN_FETCH_MAX_CONCURRENT=4

DOUYIN_HTTP_MAX_ATTEMPTS=5
DOUYIN_HTTP_RETRY_BACKOFF_BASE=0.5
WORKER_MAX_JOBS=2
WORKER_JOB_TIMEOUT=900

UPSTREAM_BASE_URL=http://host.docker.internal:19003
